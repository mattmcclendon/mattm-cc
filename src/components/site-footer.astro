---
import Linkedin from './icons/linkedin.astro';
import Facebook from './icons/facebook.astro';
import Github from './icons/github.astro';
---

<footer class="site-footer">
	<p>© 2026 Matthew McClendon. All Rights Reserved.</p>

	<div class="footer-right">
		<nav class="footer-legal" aria-label="Legal navigation">
			<a href="/legal/privacy-policy/">Privacy Policy</a>
			<a href="/legal/terms-of-use/">Terms of Use</a>
			<a href="/legal/usage-and-attribution/">Usage &amp; Attribution</a>
			<a href="#page-title" class="back-to-top" aria-label="Back to top">↗</a>
		</nav>

		<div class="footer-social" aria-label="Social links">
			<a href="https://www.linkedin.com" aria-label="LinkedIn"><Linkedin /></a>
			<a href="https://www.facebook.com" aria-label="Facebook"><Facebook /></a>
			<a href="https://github.com" aria-label="GitHub"><Github /></a>
		</div>
	</div>
</footer>

<style>
	.site-footer {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 2rem;
		padding-block: 2rem;
		border-top: 1px solid var(--page-rule);
		font-size: clamp(0.68rem, 0.9vw, 0.78rem);
		font-weight: 600;
		letter-spacing: 0.12em;
		line-height: 1;
		text-transform: uppercase;
		color: var(--page-muted);
	}

	.site-footer p {
		margin: 0;
	}

	.site-footer a {
		color: inherit;
		text-decoration: none;
		transition: color 180ms ease;
	}

	.site-footer a:hover {
		color: var(--page-accent);
	}

	.footer-right {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
	}

	.footer-legal {
		display: flex;
		align-items: center;
		gap: 1.25rem;
		font-size: 0.75rem;
	}

	.footer-social {
		display: flex;
		gap: 1.25rem;
		margin-top: 60px;
	}

	.footer-social a {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		color: inherit;
		opacity: 1;
		transition: opacity 180ms ease, transform 180ms ease, color 180ms ease;
	}

	.footer-social a:hover {
		opacity: 1;
		transform: translateY(-2px);
	}

	.footer-social svg {
		display: block;
		width: 24px !important;
		height: 24px !important;
		max-width: 24px;
		max-height: 24px;
		stroke: currentColor;
		fill: currentColor;
		color: currentColor;
	}

	.footer-social svg,
	.footer-social svg * {
		fill: currentColor !important;
		stroke: currentColor !important;
	}

	.back-to-top {
		opacity: 0.45;
		font-size: 1rem;
		transition:
			opacity 180ms ease,
			color 180ms ease,
			transform 180ms ease;
	}

	.back-to-top:hover {
		opacity: 1;
		transform: translateY(-2px);
	}

	@media (max-width: 760px) {
		.site-footer {
			align-items: flex-start;
			flex-direction: column;
		}

		.footer-right {
			align-items: flex-start;
		}

		.footer-social {
			margin-top: 2rem;
		}
	}
</style>

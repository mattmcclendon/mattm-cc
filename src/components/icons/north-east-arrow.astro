---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<svg
	class:list={['direction-arrow', className]}
	xmlns="http://www.w3.org/2000/svg"
	viewBox="0 0 24 24"
	aria-hidden="true"
	focusable="false"
>
	<path d="M10 2h12v12l-4 4V9.5l-11 11L3.5 17 14.5 6H7l3-4Z" />
</svg>

<style>
	.direction-arrow {
		display: block;
		width: 1em;
		height: 1em;
		fill: currentColor;
		flex: 0 0 auto;
	}
</style>

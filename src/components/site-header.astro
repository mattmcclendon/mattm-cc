---
import PrimaryNav from './primary-nav.astro';

interface Props {
	current?: 'home' | 'chronology' | 'resume' | 'philosophy' | 'case-studies' | 'about';
}

const { current = 'home' } = Astro.props;
---

<header class="site-header">
	<a class="site-brand" href="/" aria-label="mattm.cc home">
		<span class="brand-mark" aria-hidden="true"></span>
		<span class="brand-name">mattm.cc</span>
	</a>

	<PrimaryNav current={current} />
</header>

<style>
	.site-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 2rem;
		padding-block: clamp(1.25rem, 2vw, 2rem);
		border-bottom: 1px solid var(--page-rule);
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.9rem;
		color: var(--page-muted);
		text-decoration: none;
		transition: color 180ms ease;
	}

	.site-brand:hover {
		color: var(--page-accent);
	}

	.brand-mark {
		width: 14px;
		height: 14px;
		background: var(--brand-color, var(--page-accent));
		border-radius: 1px;
		flex: 0 0 14px;
	}

	.brand-name {
		font-size: clamp(0.78rem, 1vw, 0.9rem);
		font-weight: 600;
		letter-spacing: 0.1em;
		line-height: 1;
		text-transform: uppercase;
	}

	@media (max-width: 760px) {
		.site-header {
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>



---
interface Props {
	src: string;
	alt: string;
	caption?: string;
	size?: 'default' | 'wide' | 'full';
	loading?: 'lazy' | 'eager';
}

const {
	src,
	alt,
	caption,
	size = 'default',
	loading = 'lazy',
} = Astro.props;
---

<figure class={`case-study-figure case-study-figure--${size}`}>
	<img src={src} alt={alt} loading={loading} decoding="async" />
	{caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
	.case-study-figure {
		margin: clamp(2.5rem, 5vw, 4rem) 0;
	}

	.case-study-figure--default {
		width: min(100%, 760px);
	}

	.case-study-figure--wide {
		width: min(100%, 960px);
	}

	.case-study-figure--full {
		width: 100%;
	}

	.case-study-figure img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: 4px;
		border: 1px solid var(--page-rule);
		background: rgba(248, 247, 244, 0.04);
	}

	.case-study-figure figcaption {
		max-width: 46rem;
		margin-top: 0.85rem;
		font-size: 0.88rem;
		font-weight: 300;
		line-height: 1.45;
		color: var(--page-muted);
	}
</style>
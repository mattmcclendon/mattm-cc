---
import PrimaryNav from './primary-nav.astro';
---

<main class="home-hero" aria-label="Matthew McClendon homepage">
	<picture class="home-hero__media">
		<source
			type="image/avif"
			srcset="/img/mmc-home-003-1280.avif 1280w, /img/mmc-home-003-2560.avif 2560w"
			sizes="100vw"
		/>
		<img
			class="home-hero__image"
			src="/img/mmc-home-003.png"
			alt=""
			width="10000"
			height="5625"
			loading="eager"
			fetchpriority="high"
			decoding="async"
			aria-hidden="true"
		/>
	</picture>

	<div class="home-hero__shade"></div>

	<div class="home-hero__nav">
		<PrimaryNav current="home" />
	</div>

<section class="home-hero__content">
	<p class="home-hero__mark">mattm.cc</p>
	<h1 class="sr-only">Matthew McClendon</h1>
	<img src="/img/matthew-mcclendon-wordmark.svg" alt="" class="home-hero__wordmark" width="1056" height="346" decoding="async" />
	<p class="home-hero__roles">Designer. Writer. Systems Thinker.</p>
</section>
</main>

<style>
	.home-hero {
		position: relative;
		isolation: isolate;
		display: grid;
		min-height: 100svh;
		overflow: hidden;
		background: #02040a;
		padding: clamp(1.25rem, 2vw, 2rem);
	}

	.home-hero__image,
	.home-hero__shade {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.home-hero__media {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.home-hero__image {
		z-index: 0;
		object-fit: cover;
		object-position: center;
		background: #02040a;
		pointer-events: none;
		transform: translate3d(0, 0, 0);
		backface-visibility: hidden;
		filter: brightness(0.94) saturate(0.96);
	}

	.home-hero__shade {
		z-index: 1;
		background:
			linear-gradient(90deg, rgba(2, 4, 10, 0.56) 0%, rgba(2, 4, 10, 0.24) 42%, rgba(2, 4, 10, 0.04) 100%),
			linear-gradient(180deg, rgba(2, 4, 10, 0.18) 0%, rgba(2, 4, 10, 0.04) 45%, rgba(2, 4, 10, 0.44) 100%);
	}

	.home-hero__nav,
	.home-hero__content {
		position: relative;
		z-index: 2;
	}

	.home-hero__nav {
		align-self: start;
		width: min(calc(100vw - 2rem), 1180px);
		margin-inline: auto;
	}

	.home-hero__content {
		align-self: center;
		max-width: 42rem;
		padding-left: clamp(0.75rem, 2vw, 1.5rem);
		padding-bottom: 5vh;
		transform: translateY(calc(3vh + 36px));
	}

	.home-hero__content::before {
		content: "";
		position: absolute;
		inset: -4rem -5rem;
		z-index: -1;
		pointer-events: none;

		background: radial-gradient(
			ellipse at 44% 48%,
			rgba(2, 4, 10, 0.48) 0%,
			rgba(2, 4, 10, 0.30) 34%,
			rgba(2, 4, 10, 0.10) 58%,
			transparent 78%
		);
	}

	.home-hero__mark {
		margin: 0 0 2.25rem;
		padding-left: 0.08rem;
		font-size: clamp(0.78rem, 1.2vw, 0.92rem);
		font-weight: 100;
		font-style: normal;
		letter-spacing: 0.24em;
		text-transform: uppercase;
		color: rgba(248, 247, 244, 0.62);
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		padding: 0;
		margin: -1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
		border: 0;
	}

	.home-hero__wordmark {
		display: block;
		width: min(100%, 38rem);
		height: auto;
	}

	.home-hero__roles {
		margin: 0;
		max-width: 36rem;
		margin-top: clamp(1.5rem, 3vw, 2.5rem);
		font-size: clamp(1rem, 1.6vw, 1.35rem);
		font-weight: 400;
		letter-spacing: 0.01em;
		color: rgba(248, 247, 244, 0.82);
	}

	@media (max-width: 720px) {
		.home-hero {
			min-height: 100dvh;
		}

		.home-hero__content {
			align-self: end;
			padding-bottom: clamp(5rem, 14vh, 8rem);
			transform: none;
		}

		.home-hero__wordmark {
			width: min(88vw, 32rem);
		}

		.home-hero__image {
			object-position: center;
		}
	}

	@media (max-height: 520px) and (orientation: landscape) {
		.home-hero__content {
			padding-bottom: 2.5rem;
			transform: none;
		}

		.home-hero__wordmark {
			width: min(52vw, 34rem);
		}

		.home-hero__roles {
			margin-top: 0.75rem;
		}

		.home-hero__nav {
			top: 1.25rem;
		}
	}
</style>

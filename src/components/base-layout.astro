---
import '../styles/global.css';
import SeoHead from './seo-head.astro';

interface Props {
	title?: string;
	description?: string;
	bodyClass?: string;
}

const {
	title = 'Matthew McClendon | mattm.cc',
	description = 'Matthew McClendon is a designer, writer, and systems thinker.',
	bodyClass = '',
} = Astro.props;
---

<html lang="en">
	<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<meta name="generator" content={Astro.generator} />
	<SeoHead title={title} description={description} />
	<link rel="stylesheet" href="https://use.typekit.net/bma7jnq.css" />
	</head>
	<body class={bodyClass}>
		<slot />
	</body>
</html>

---
import { getCollection, render, type CollectionEntry } from 'astro:content';
import CaseStudyLayout from '../../components/case-study-layout.astro';

export async function getStaticPaths() {
	const studies = await getCollection('caseStudies', ({ data }) => !data.draft);

	return studies.map((study) => ({
		params: { slug: study.id },
		props: { study },
	}));
}

interface Props {
	study: CollectionEntry<'caseStudies'>;
}

const { study } = Astro.props;
const { Content } = await render(study);
---

<CaseStudyLayout study={study}>
	<Content />
</CaseStudyLayout>

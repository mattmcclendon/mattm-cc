

---
import PageLayout from '../../../components/page-layout.astro';
---

<PageLayout
	title="Privacy Policy"
	description="Privacy practices for mattm.cc."
	intro="How mattm.cc collects, uses, and protects information."
	variant="legal"
>
	<section class="page-section" aria-labelledby="effective-date-title">
		<h2 id="effective-date-title">Effective Date</h2>
		<div class="prose">
			<p>April 2026</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="overview-title">
		<h2 id="overview-title">Overview</h2>
		<div class="prose">
			<p>
				mattm.cc respects your privacy. This policy explains what information may be collected when you visit the site, how it is used, and the choices available to you.
			</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="collection-title">
		<h2 id="collection-title">Information Collected</h2>
		<div class="prose">
			<p>
				The site may collect standard server logs, basic analytics, and information you voluntarily provide through email or other direct communication. No account is required to read the site.
			</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="usage-title">
		<h2 id="usage-title">How Information Is Used</h2>
		<div class="prose">
			<p>
				Information is used to understand site performance, improve content, respond to correspondence, and maintain the security and reliability of the site.
			</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="third-party-title">
		<h2 id="third-party-title">Third-Party Services</h2>
		<div class="prose">
			<p>
				The site may use services such as Vercel, GitHub, Google Analytics, and Pagefind. Those services operate under their own privacy policies.
			</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="contact-title">
		<h2 id="contact-title">Questions</h2>
		<div class="prose">
			<p>Questions about this policy may be sent to <a href="mailto:info@amidthenoise.com">info@amidthenoise.com</a>.</p>
		</div>
	</section>
</PageLayout>
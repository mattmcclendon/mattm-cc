

---
import PageLayout from '../../../components/page-layout.astro';
---

<PageLayout
	title="Terms of Use"
	description="Terms of use for mattm.cc."
	intro="The terms that govern access to and use of mattm.cc."
	variant="legal"
>
	<section class="page-section" aria-labelledby="effective-date-title">
		<h2 id="effective-date-title">Effective Date</h2>
		<div class="prose">
			<p>April 2026</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="overview-title">
		<h2 id="overview-title">Overview</h2>
		<div class="prose">
			<p>
				mattm.cc is the professional and personal site of Matthew McClendon. By
				accessing or using this site, you agree to use it in a lawful, respectful,
				and responsible manner.
			</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="content-title">
		<h2 id="content-title">Content</h2>
		<div class="prose">
			<p>
				The site may include résumé materials, project descriptions, essays,
				images, diagrams, links, references, and other materials related to Matthew
				McClendon’s professional and creative work.
			</p>
			<p>
				Content is provided for informational and professional context. It should
				not be treated as legal, financial, medical, or other professional advice.
			</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="acceptable-use-title">
		<h2 id="acceptable-use-title">Acceptable Use</h2>
		<div class="prose">
			<p>
				You may browse, link to, cite, and discuss content on this site, subject to
				the Usage &amp; Attribution page and applicable law.
			</p>
			<p>
				You may not attempt to interfere with the operation, security, integrity,
				or availability of the site.
			</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="links-title">
		<h2 id="links-title">External Links</h2>
		<div class="prose">
			<p>
				This site may link to external websites, publications, profiles, projects,
				or services. Those external sites are governed by their own terms and
				policies.
			</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="availability-title">
		<h2 id="availability-title">Availability</h2>
		<div class="prose">
			<p>
				The site may change, move, or become unavailable without notice. Content may
				be updated, corrected, revised, removed, or reorganized over time.
			</p>
		</div>
	</section>

	<section class="page-section" aria-labelledby="questions-title">
		<h2 id="questions-title">Questions</h2>
		<div class="prose">
			<p>
				Questions about these terms may be sent to <a href="mailto:info@amidthenoise.com">info@amidthenoise.com</a>.
			</p>
		</div>
	</section>
</PageLayout>